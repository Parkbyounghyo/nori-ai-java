  151| 		PaginationInfo paginationInfo = new PaginationInfo();
  152| 		
  153| 		paginationInfo.setCurrentPageNo(dt.getInt("currPage",1));		// 현재페이지
  154| 		paginationInfo.setRecordCountPerPage(dt.getInt("list_limit",10));	// 페이지당 보여줄 리스트수
  155| 		paginationInfo.setPageSize(dt.getInt("pageSize",10));				// 보여줄 페이지
  156| 		
  157| 		dt.put("firstIndex",paginationInfo.getFirstRecordIndex());
  158| 		dt.put("lastIndex",paginationInfo.getLastRecordIndex());
  159| 		dt.put("recordCountPerPage",paginationInfo.getRecordCountPerPage());
  160| 		
  161| 		dt.put("boa_type","4");
