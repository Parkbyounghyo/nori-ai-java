  165| 		LOGGER.info("listCnt >>>> " + listCnt);
  166| 		paginationInfo.setTotalRecordCount(listCnt);
  167| 		model.addAttribute("paginationInfo", paginationInfo);
  168| 		
  169| 		//** pageing setting end *//
