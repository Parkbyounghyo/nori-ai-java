# ── Nori AI 서버 환경설정 ──
# Ollama 로컬 LLM 사용 (보안망 환경)

# AI 프로바이더: ollama (로컬) | openai (클라우드)
NORI_AI_PROVIDER=ollama

# OpenAI 키 (ollama 사용 시 불필요)
NORI_AI_API_KEY=

# Ollama 설정
NORI_OLLAMA_BASE_URL=http://localhost:11434
NORI_OLLAMA_MODEL=qwen2.5-coder:7b

# 생성 파라미터
NORI_AI_TEMPERATURE=0.2
NORI_AI_MAX_TOKENS=4096

# 서버 인증 (비워두면 인증 비활성)
NORI_API_KEY=
