      <!-- Console 뷰 우클릭 (에러 분석) — Process Console (Tomcat 서버 등) -->
      <menuContribution locationURI="popup:org.eclipse.debug.ui.ProcessConsoleType.#ContextMenu?after=additions">
         <menu id="nori.ai.menu.console.process" label="Nori AI">
