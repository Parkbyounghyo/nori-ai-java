<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <!-- ========== View ========== -->
   <extension point="org.eclipse.ui.views">
      <category id="nori.ai.category" name="Nori AI"/>
      <view
         id="nori.ai.views.side"
         name="Nori AI 어시스턴트"
         category="nori.ai.category"
         class="nori.ai.plugin.views.NoriSideView"
         allowMultiple="false"
         restorable="true"/>
   </extension>

   <!-- ========== Commands ========== -->
   <extension point="org.eclipse.ui.commands">
      <category id="nori.ai.commands.category" name="Nori AI" description="Nori AI 코드 도우미"/>
      <command id="nori.ai.command.explain" name="코드 설명" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.review" name="코드 리뷰" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.refactor" name="리팩토링" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.testGenerate" name="테스트 생성" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.docGenerate" name="JavaDoc 생성" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.errorAnalyze" name="에러 분석" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.errorFix" name="자동 수정" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.generate" name="코드 생성" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.schemaScan" name="DB 스키마 스캔" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.apiScan" name="API 매핑 스캔" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.errorLog" name="에러 기록" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.convention" name="코딩 컨벤션" categoryId="nori.ai.commands.category"/>
      <command id="nori.ai.command.profileUpdate" name="현재 파일 AI 분석" categoryId="nori.ai.commands.category"/>
   </extension>

   <!-- ========== Handlers ========== -->
   <extension point="org.eclipse.ui.handlers">
      <handler commandId="nori.ai.command.explain" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.review" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.refactor" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.testGenerate" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.docGenerate" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.errorAnalyze" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.errorFix" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.generate" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.schemaScan" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.apiScan" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.errorLog" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.convention" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
      <handler commandId="nori.ai.command.profileUpdate" class="nori.ai.plugin.handlers.NoriCommandHandler"/>
   </extension>

